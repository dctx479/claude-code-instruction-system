# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly LF for scripts and text files
*.sh    text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files - no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.gz    binary
