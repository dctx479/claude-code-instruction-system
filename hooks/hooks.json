{
  "version": "3.2.0",
  "description": "Taiyi System Hooks Configuration",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Writing file...'",
            "description": "文件写入前通知"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./scripts/validate-command.sh\"",
            "description": "验证 Bash 命令安全性",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python ./scripts/port-management/port-check-hook.py",
            "description": "检查 Docker 端口冲突",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/agent-tracker.sh\"",
            "description": "跟踪当前活动的 Agent",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File write completed'",
            "description": "文件写入后通知"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./scripts/post-edit.sh\"",
            "description": "编辑后运行 lint 检查",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/intent-detector.sh\"",
            "description": "Intent Detector - 智能意图识别",
            "timeout": 3000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./scripts/notify.sh\"",
            "description": "发送通知到外部系统"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/ralph-stop-interceptor.sh\"",
            "description": "Ralph Loop 停止拦截器 - 检查是否继续执行",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash \"./scripts/on-stop.sh\"",
            "description": "会话结束时的清理操作"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/pre-compact.sh\"",
            "description": "上下文压缩前自动归档",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "notes": {
    "exit_codes": {
      "0": "继续执行",
      "1": "记录错误并继续",
      "2": "阻止工具执行"
    },
    "environment_variables": {
      "TOOL_NAME": "工具名称",
      "TOOL_INPUT": "工具输入 (JSON, via stdin)",
      "TOOL_OUTPUT": "工具输出 (PostToolUse, via stdin)",
      "SESSION_ID": "会话 ID"
    },
    "platform": {
      "windows": "需要在 PATH 中有 bash (Git Bash)。如系统未识别 bash 命令，可用绝对路径替代。",
      "macos_linux": "直接使用 bash 命令即可"
    }
  }
}
