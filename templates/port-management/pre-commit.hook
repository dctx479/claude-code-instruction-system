#!/bin/bash
# Git Pre-commit Hook - 端口配置验证
# 将此文件复制到 .git/hooks/pre-commit

set -e

# 检查是否有端口配置文件变更
CHANGED_FILES=$(git diff --cached --name-only)

if echo "$CHANGED_FILES" | grep -qE '\.env|docker-compose\.yml|port-registry\.json'; then
    echo "Checking port configuration..."
    
    # 运行端口冲突检测
    if command -v python &> /dev/null; then
        python scripts/port-manager.py conflicts --quiet 2>/dev/null
        if [ $? -ne 0 ]; then
            echo ""
            echo "ERROR: Port conflict detected!"
            echo "Please resolve conflicts before committing."
            echo ""
            echo "Run: python scripts/port-manager.py conflicts"
            exit 1
        fi
    fi
    
    echo "Port configuration OK"
fi

exit 0
