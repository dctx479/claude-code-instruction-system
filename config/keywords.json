  "patterns": {
    "question": {
      "regex": "^(what|how|why|when|where|who|which|是什么|怎么|为什么|什么时候|哪里|谁|哪个)",
      "boost": 0.5
    },
    "command": {
      "regex": "^(create|delete|update|fix|add|remove|make|build|run|创建|删除|更新|修复|添加|移除|构建|运行)",
      "boost": 0.8
    },
    "request": {
      "regex": "(please|帮我|请|能否|可以)",
      "boost": 0.3
    }
  },
  "fallback": {
    "agent": "orchestrator",
    "skills": [],
